# ──────────────────────────────────────────────────────────
# WASM-RPG .gitignore — Production-Grade
# ──────────────────────────────────────────────────────────

# ── Toolchains (Local Dev Only) ────────────────────────────
# Emscripten SDK (~1.8GB)
emsdk/
# NPM dependencies
**/node_modules/

# ── Build & Compiled Artifacts ─────────────────────────────
# CMake build directory
engine/build/
# WASM compiler output location
engine/frontend/
# Object/library files
*.o
*.a
*.so
*.dylib
# WASM binaries (commit .js bridge only when intentionally needed)
*.wasm
# Production builds
**/dist/
# Generic build artifacts
build/
# TypeScript incremental artifacts
*.tsbuildinfo
# Generated Vite config outputs
frontend/vite.config.js
frontend/vite.config.d.ts

# ── IDE & Environment ──────────────────────────────────────
# Local VS Code settings
.vscode/settings.json
# Local debug configs
.vscode/launch.json
# Environment variables
.env
.env.local
# Vim temp files
*.swp
*.swo
# macOS
.DS_Store
# Windows
Thumbs.db

# ── Python ─────────────────────────────────────────────────
# Python cache
__pycache__/
# Compiled Python
*.py[cod]
# Package metadata
*.egg-info/
# Test cache
.pytest_cache/
# Virtual environments
venv/
.venv/

# ── Database (Local Dev SQLite) ────────────────────────────
# Local SQLite (not production state)
member2/backend/database.db*

# ── Private & Sensitive ────────────────────────────────────
# Cryptographic keys
*.key
*.pem
*.pfx
# Secret management folder
.secrets/

# ── Archives / binary drops ────────────────────────────────
*.rar
*.zip

# ── OS & Temp ──────────────────────────────────────────────
# Log files
*.log
# Temp & debug data
*.tmp
*.pdb
