# Copy this file to .env and add your real key(s).
# .env is ignored by git.

# Select provider: auto | gemini | openrouter
# - auto: prefers OpenRouter when OPENROUTER_API_KEY is present, else Gemini.
LESSON_AI_PROVIDER=auto

# Gemini config (optional)
GEMINI_API_KEY=PASTE_YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-2.5-flash

# OpenRouter config (recommended if Gemini rate-limited)
OPENROUTER_API_KEY=PASTE_YOUR_OPENROUTER_API_KEY_HERE
OPENROUTER_MODEL=google/gemma-3-27b-it:free

# Optional comma-separated fallbacks tried automatically on provider/rate-limit failures.
# OPENROUTER_FALLBACK_MODELS=google/gemma-3-12b-it:free,openai/gpt-oss-20b:free,qwen/qwen3-coder:free

# Optional OpenRouter headers (recommended in production)
# OPENROUTER_SITE_URL=https://your-site.example
# OPENROUTER_APP_NAME=wasm-rpg-neofuture

# Runtime environment: development | production
ENV=development

# CORS (used when ENV=production)
# Comma-separated allowlist for frontend origins.
# Example: CORS_ORIGINS=https://app.example.com,https://staging.example.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Request logging
LOG_LEVEL=INFO
LOG_HEALTHCHECKS=false

# API rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_EXEMPT_PATHS=/health,/docs,/openapi.json,/redoc
